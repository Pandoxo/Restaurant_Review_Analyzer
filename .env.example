# Google Places API key (from Google Cloud Console)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Outscraper API key (from https://outscraper.com/)
OUTSCRAPER_API_KEY=your_outscraper_api_key_here

# ── LLM Backend ────────────────────────────────────────────
# Choose: "gemini" (free, no GPU) or "ollama" (local GPU)
LLM_BACKEND=gemini

# Gemini API key (from https://aistudio.google.com/apikey)
# Free tier: leave GEMINI_DELAY_SECONDS at 4.5
# Tier 1 Paid: change GEMINI_DELAY_SECONDS to 0.3 (or 0.2) for ~200-300 RPM
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_DELAY_SECONDS=0.3

# Ollama settings (only if LLM_BACKEND=ollama)
OLLAMA_MODEL=qwen3:8b
OLLAMA_URL=http://localhost:11434
